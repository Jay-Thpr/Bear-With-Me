# Gemini API — get from https://aistudio.google.com/
# TODO: set GEMINI_API_KEY in .env.local
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# NextAuth + Google OAuth — required if you want Docs/Calendar writes in the signed-in user's account
# Redirect URI to register in Google Cloud Console:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
NEXTAUTH_SECRET=your_random_base64_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google Service Account — downloaded from Google Cloud Console > IAM > Service Accounts
# Either provide a file path OR paste the JSON inline (not both)
# TODO: set GOOGLE_SERVICE_ACCOUNT_KEY_PATH in .env.local
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: YouTube Data API key — for fallback video search if Gemini grounding returns < 3 URLs
# Get from Google Cloud Console > APIs & Services > Credentials
# TODO: set YOUTUBE_API_KEY in .env.local
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Google Drive folder ID to organize created Docs
# Get from the folder's URL: https://drive.google.com/drive/folders/{FOLDER_ID}
# TODO: set GOOGLE_DRIVE_FOLDER_ID in .env.local
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# WebSocket server port (default: 3001)
WS_PORT=3001
